# Local-dev defaults for url_content_extraction_service.
# Copy to .env (or rely on the central .env at the repo root).

# Supabase project that hosts the shared `extraction_jobs` table.
# Required for both the worker and the cleanup CLI.
SUPABASE_URL=""
SUPABASE_KEY=""

# Submit fires off requests to this URL after creating a job. For local dev
# the local_server.py sets this to http://localhost:8080/worker automatically.
WORKER_URL=""

# Shared secret enforced by the /worker handler. Leave empty to disable auth
# locally; production deploys MUST set this in the function environment.
WORKER_TOKEN=""

# Verbosity for the worker + cleanup CLI.
LOG_LEVEL="INFO"
