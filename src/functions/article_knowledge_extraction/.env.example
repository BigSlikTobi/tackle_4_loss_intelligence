# Article Knowledge Extraction — environment variables
#
# All domain credentials (OpenAI, Supabase) are supplied per-request in the
# HTTP payload; only generic Cloud-Function-level settings live here.

LOG_LEVEL=INFO

# Shared secret between the submit and worker endpoints. Submit sends this
# header to the worker; worker verifies it. Rotate by re-running deploy.sh.
WORKER_TOKEN=

# Absolute URL of the deployed worker endpoint. Submit fire-and-forgets to this
# URL after writing the queued row. Set at deploy time.
WORKER_URL=

# Optional: defaults used when a request omits llm / supabase blocks. These are
# only for local CLI convenience — the Cloud Function should receive per-request
# credentials instead.
OPENAI_API_KEY=
SUPABASE_URL=
SUPABASE_KEY=
