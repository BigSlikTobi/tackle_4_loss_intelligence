# Local-dev defaults for news_extraction_service.
# Copy to .env or rely on the central .env at the repo root.

SUPABASE_URL=""
SUPABASE_KEY=""

# Submit fires off requests to this URL after creating a job. local_server.py
# sets it to http://localhost:8080/worker automatically for local dev.
WORKER_URL=""

# Shared secret enforced by the /worker handler. Leave empty to disable auth
# locally; production deploys MUST set this in the function environment.
WORKER_TOKEN=""

LOG_LEVEL="INFO"
