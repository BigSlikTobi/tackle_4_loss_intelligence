# Local-dev defaults for gemini_tts_batch_service.
# Copy to .env (or rely on the central .env at the repo root).

# Supabase project that hosts the shared `extraction_jobs` table.
# Required for both the worker and the cleanup CLI.
SUPABASE_URL=""
SUPABASE_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Caller-facing bearer token for /submit and /poll. Required in production;
# may be unset locally to bypass auth.
TTS_BATCH_FUNCTION_AUTH_TOKEN=""

# Submit fires off requests to this URL after creating a job. For local dev
# the local_server.py sets this to http://localhost:8080/worker automatically.
WORKER_URL=""

# Shared secret enforced by the /worker handler. Leave empty to disable auth
# locally; production deploys MUST set this in the function environment.
WORKER_TOKEN=""

# Gemini API key used by the worker for action=create / status / process.
GEMINI_API_KEY=""

# Storage bucket host for action=process. Defaults to the same project as
# the jobs DB (SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY) if unset.
STORAGE_SUPABASE_URL=""
STORAGE_SUPABASE_KEY=""

# Verbosity for the worker + cleanup CLI.
LOG_LEVEL="INFO"
